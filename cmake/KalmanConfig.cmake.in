#                                               -*- cmake -*-
#
#  KalmanConfig.cmake
#
#  CMake package configuration file for the header-only Kalman filter library.
#  Allows consumers to do:
#
#      find_package(Kalman REQUIRED)
#      target_link_libraries(my_target PRIVATE Kalman::Kalman)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Eigen3 3.3 NO_MODULE)

include("${CMAKE_CURRENT_LIST_DIR}/KalmanTargets.cmake")

check_required_components(Kalman)
